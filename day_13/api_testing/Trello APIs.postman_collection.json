  "item": [
    {
      "name": "Create a Trello Board",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const jsonData = pm.response.json();",
              "",
              "pm.environment.set(\"boardId\", jsonData.id);",
              "",
              "pm.test(\"Response has id\", function () {",
              "    pm.expect(jsonData).to.have.property(\"id\");",
              "});",
              "",
              "pm.test(\"Response has name\", function () {",
              "    pm.expect(jsonData).to.have.property(\"name\");",
              "});",
              "",
              "pm.test(\"Response has url\", function () {",
              "    pm.expect(jsonData).to.have.property(\"url\");",
              "});",
              "",
              "createdBoardName = pm.environment.get(\"dynamicBoardId\")",
              "pm.test(\"Board name is correct\", function () {",
              "    pm.expect(jsonData.name).to.eql(createdBoardName);",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "let randomNum = Math.floor(Math.random() * 1000).toString().padStart(3, '0');\t\r",
              "\r",
              "let uniqueValue = `Postman Board ${randomNum}`;\r",
              "\r",
              "pm.environment.set(\"dynamicBoardId\", uniqueValue);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "auth": {
          "type": "apikey",
          "apikey": [
            {
              "key": "value",
              "value": "12047622-b747-4002-af0e-9d1819b952ae",
              "type": "string"
            },
            {
              "key": "key",
              "value": "x-api-key",
              "type": "string"
            }
          ]
        },
        "method": "POST",
        "header": [],
        "url": {
          "raw": "{{base_url}}/1/boards/?name={{dynamicBoardId}}&key={{key}}&token={{token}}",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "1",
            "boards",
            ""
          ],
          "query": [
            {
              "key": "name",
              "value": "{{dynamicBoardId}}"
            },
            {
              "key": "key",
              "value": "{{key}}"
            },
            {
              "key": "token",
              "value": "{{token}}"
            }
          ]
        },
        "description": "Generated from cURL: curl --request POST \\\r\n  --url 'https://api.trello.com/1/boards/?name={name}&key=APIKey&token=APIToken'"
      },
      "response": []
